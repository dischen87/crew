{
  "name": "crew",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "concurrently \"bun run dev:api\" \"bun run dev:web\"",
    "dev:api": "cd packages/api && bun run dev",
    "dev:web": "cd packages/web && bun run dev",
    "db:setup": "cd packages/api && bun run db:setup",
    "db:seed": "cd packages/api && bun run db:seed",
    "db:seed-belek": "cd packages/api && bun run db:seed-belek",
    "staging:up": "docker compose up -d && sleep 2 && bun run db:setup && bun run db:seed && bun run dev"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
