# Crew Staging Environment
NODE_ENV=staging

# PostgreSQL
DATABASE_URL=postgres://crew:crew_staging@localhost:5432/crew_staging

# Redis
REDIS_URL=redis://localhost:6379

# API
API_PORT=3000
API_HOST=0.0.0.0

# Web
WEB_PORT=5173

# Auth
INVITE_SECRET=staging-secret-change-in-production

# Media (local for staging, Hetzner S3 later)
MEDIA_STORAGE=local
MEDIA_PATH=./uploads
